# ============================================================
# Скопируйте в .env и заполните реальными значениями
# ============================================================

# Server
BACKEND_PORT=8000

# Django
DJANGO_SECRET_KEY=change-this-to-a-random-50-char-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com
DJANGO_LOG_LEVEL=INFO

# PostgreSQL (используется и Django, и docker-compose)
DATABASE_URL=postgres://homex:STRONG_PASSWORD@db:5432/homex
POSTGRES_DB=homex
POSTGRES_USER=homex
POSTGRES_PASSWORD=STRONG_PASSWORD

# Redis
REDIS_URL=redis://redis:6379/0

# CORS
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Media
MEDIA_URL=/media/
MEDIA_ROOT=/app/media

# Database backups (.sql)
# Files are written to /app/backups inside the container. docker-compose mounts
# the host dir /srv/homex/backups there — create it on the server:
#   sudo mkdir -p /srv/homex/backups
# BACKUP_ROOT=/app/backups   # default, override only if you mount elsewhere
BACKUP_KEEP=30               # how many backups to keep (older ones are pruned)

# Внешние провайдеры
# SMS (OTP) — Eskiz. Prod uchun SMS_EMAIL/SMS_PASSWORD ni real creds bilan to'ldiring
# (bo'sh bo'lsa app boot bo'lmaydi — integrations.E001 check). SMS_FROM = Eskiz TASDIQLAGAN
# sender nickname bo'lishi kerak; 4546 faqat test-sender (real foydalanuvchilarga yetkazmaydi).
SMS_PROVIDER=eskiz
SMS_EMAIL=
SMS_PASSWORD=
SMS_FROM=
# Play Market review uchun static client OTP: shu raqam + OTP bilan SMS'siz, expire'siz
# kirish. Bo'sh qoldirilsa feature butunlay o'chiq. Doimiy "backdoor" bo'lgani uchun:
# alohida test raqam ishlating (haqiqiy user emas) va OTP ni maxfiy saqlang.
PLAYMARKET_TEST_PHONE=
PLAYMARKET_TEST_OTP=
FCM_PROVIDER=firebase
FIREBASE_CREDENTIALS_PATH=/run/secrets/firebase-service-account.json
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_B64=
FIREBASE_APP_NAME=[DEFAULT]
PAYMENT_PROVIDER=stub
MAPS_PROVIDER=stub
GOOGLE_MAPS_API_KEY=

# Payme (Paycom) Merchant API — kassaga beriladigan endpoint: POST /api/v1/payme/
# Prod: PAYME_TEST_MODE=false, PAYME_KEY = kassadagi haqiqiy kalit. Sandbox tugagach o'ting.
# PAYME_ALLOWED_IPS — Payme server IP'lari bilan cheklash (bo'sh bo'lsa tekshiruv o'chiq).
PAYME_MERCHANT_ID=
PAYME_KEY=
PAYME_TEST_KEY=
PAYME_TEST_MODE=false
PAYME_ACCOUNT_FIELD=order_id
PAYME_CHECKOUT_URL=https://checkout.paycom.uz
PAYME_RETURN_DEEPLINK=homex://payment/result
PAYME_CHECKOUT_LANG=uz
PAYME_ONE_TIME_PAYMENT=true
PAYME_ALLOWED_IPS=

DEFAULT_FROM_PHONE=HomeX
